// For format details, see https://aka.ms/devcontainer.json. For config options, see the README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.191.1/containers/debian
{
	"name": "Debian",
	"build": {
		"dockerfile": "Dockerfile"
		// Update 'VARIANT' to pick an Debian version: bullseye, buster, stretch
	},
	"secrets": {
		"EMAIL_DEV_SMTP_PASSWORD": {}
	},
	"containerEnv": {
		"MYSQL_DEV_DB_NAME": "KMP_DEV",
		"MYSQL_DEV_USERNAME": "KMPSQLDEV",
		"MYSQL_DEV_PASSWORD": "P@ssw0rd",
		"EMAIL_DEV_SMTP_HOST": "localhost",
		"EMAIL_DEV_SMTP_PORT": "1025",
		"EMAIL_DEV_SMTP_USERNAME": "testuser",
		"EMAIL_DEV_SMTP_PASSWORD": "testpass",
		"MP_SMTP_AUTH": "testuser:testpass",
		"MP_SMTP_AUTH_ALLOW_INSECURE": "true",
		"REPO_PATH": "${containerWorkspaceFolder}",
		"REPO_ROOT_PATH": "${containerWorkspaceFolderBasename}",
		"DISPLAY": "host.docker.internal:0"
	},
	// Add the IDs of extensions you want installed when the container is created.
	"customizations": {
		"vscode": {
			"extensions": [
				"cweijan.vscode-mysql-client2",
				"xdebug.php-debug",
				"bmewburn.vscode-intelephense-client",
				"rifi2k.format-html-in-php",
				"GitHub.copilot",
				"alexkrechik.cucumberautocomplete"
			],
			"settings": {}
		}
	},
	"remoteUser": "vscode",
	"initializeCommand": "mkdir -p .container-home/vscode/.config .container-home/vscode/.copilot .container-home/vscode/.ssh",
	"mounts": [
		"source=${localWorkspaceFolder}/.container-home/vscode/.config,target=/home/vscode/.config,type=bind,consistency=cached",
		"source=${localWorkspaceFolder}/.container-home/vscode/.copilot,target=/home/vscode/.copilot,type=bind,consistency=cached",
		"source=${localWorkspaceFolder}/.container-home/vscode/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
	],
	"forwardPorts": [
		8080, // Port for the application server
		3306, // Port for MySQL server
		5432, // Port for PostgreSQL server (matches Azure Flex target)
		8025, // Port for Mailpit SMTP server
		9324 // Port for Playwright test report
	],
	"appPort": [
		"8080:8080",
		"8025:8025",
		"9324:9324"
	],
	"runArgs": [
		"--add-host=host.docker.internal:host-gateway",
		"--env=DISPLAY=host.docker.internal:0"
	],
	"postStartCommand": "bash .devcontainer/init_env/config_space.sh"
}