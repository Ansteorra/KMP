# KMP Azure Nightly — Settings Template
#
# Copy this file to `nightly.env` (same directory) and fill in every value
# **without quotes** and **without spaces around `=`**. Values become either
# Key Vault secrets or Container App env vars during deployment.
#
#   cp deploy/azure/nightly.env.example deploy/azure/nightly.env
#   # edit deploy/azure/nightly.env
#
# `nightly.env` is gitignored — NEVER commit real credentials.
#
# Lines starting with `#` are comments. Leave a value blank to accept the
# default shown in [brackets].

# =============================================================================
# Azure target
# =============================================================================
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_REGION=
# Resource group that will hold every nightly resource. [kmp-nightly-rg]
AZURE_RESOURCE_GROUP=kmp-nightly-rg
# Short prefix used for resource names. Must be 3–11 lowercase alphanumerics.
# Final names will be `<prefix>-web`, `<prefix>acr...`, `<prefix>-pg-...`, etc. [kmpnightly]
AZURE_NAME_PREFIX=kmpnightly

# =============================================================================
# Application secrets (written to Azure Key Vault, referenced by Container Apps)
# =============================================================================
# 32+ random chars. Generate with: openssl rand -hex 32
SECURITY_SALT=

# Postgres Flex admin password. Must be 8-128 chars with upper, lower, digit.
# Generate: openssl rand -base64 24 | tr -d '/+=' | cut -c1-24
# The nightly env uses admin credentials directly (no separate app role) —
# simpler, and the overhead of a least-privilege role isn't worth it for a
# throwaway demo DB that gets rebuilt by every reset job.
POSTGRES_ADMIN_PASSWORD=

# Symmetric key used to encrypt/decrypt the bundled seed backup
# (deploy/azure/seed/nightly-seed.kmpbackup). Must match the key that was
# used when running deploy/azure/seed/bake-seed.sh. The reset Container
# Apps Job fetches this from Key Vault at run time.
#
# Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# Master key for the database-backed platform secret store. This protects
# tenant database passwords and other platform-managed secrets stored in the
# platform metadata database. Generate a different value from BACKUP_ENCRYPTION_KEY.
# Generate: openssl rand -hex 32
PLATFORM_SECRETS_MASTER_KEY=

# =============================================================================
# Email (Mailpit in UAT — reuse it)
# =============================================================================
# EMAIL_DRIVER must be `smtp` for Mailpit.
EMAIL_DRIVER=smtp
# Mailpit host that the Azure Container App can reach over the public internet.
# e.g. mailpit.uat.example.org — must resolve publicly from Azure.
EMAIL_SMTP_HOST=
# Mailpit SMTP port. Default Mailpit SMTP is 1025 (unauthenticated). [1025]
EMAIL_SMTP_PORT=1025
# Leave empty if your Mailpit does not require SMTP auth.
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
# true only if your Mailpit is behind TLS. Mailpit default is plain. [false]
EMAIL_SMTP_TLS=false
# From address on outgoing mail. e.g. nightly-noreply@ansteorra.org
EMAIL_FROM=nightly-noreply@example.org

# =============================================================================
# App runtime
# =============================================================================
# true/false — keep false for nightly unless actively debugging. [false]
DEBUG=false
# Container Apps fronts ingress with HTTPS; keep this true. [true]
REQUIRE_HTTPS=true

# =============================================================================
# Optional — leave commented unless you want blob storage for uploads
# =============================================================================
# DOCUMENT_STORAGE_ADAPTER=azure
# Prefer managed identity/RBAC in Azure; no storage account keys are needed.
# AZURE_STORAGE_AUTH_MODE=managedIdentity
# AZURE_STORAGE_ACCOUNT_NAME=<provisioned-storage-account-name>
# AZURE_STORAGE_CONTAINER_PREFIX=documents
# Legacy/dev-only fallback:
# AZURE_STORAGE_CONNECTION_STRING=

# =============================================================================
# GitHub OIDC (populated during bootstrap, you don't edit these)
# =============================================================================
# These are written automatically by `deploy/azure/bootstrap.sh` after creating
# the AAD app; they get pushed to GitHub repo secrets via `gh secret set`.
# AZURE_CLIENT_ID=
