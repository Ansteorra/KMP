{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite build --mode development",
        "build": "vite build",
        "prod": "npm run build",
        "production": "npm run build",
        "watch": "vite build --watch",
        "docs:js": "jsdoc -c jsdoc.config.json",
        "test": "npm run test:js && npm run test:ui:uat",
        "test:js": "jest",
        "test:js:watch": "jest --watch",
        "test:js:coverage": "jest --coverage",
        "test:js:coverage:security": "bash bin/run-jest-coverage.sh security",
        "test:ui": "npm run test:ui:uat",
        "test:ui:smoke": "bash bin/run-playwright-lane.sh smoke",
        "test:ui:journey": "bash bin/run-playwright-lane.sh journey",
        "test:ui:platform-provisioning": "bash bin/run-playwright-lane.sh platform",
        "test:ui:uat": "bash bin/run-playwright-lane.sh uat",
        "test:ui:headed": "bash bin/run-playwright-lane.sh uat --headed",
        "test:ui:debug": "bash bin/run-playwright-lane.sh uat --debug",
        "test:ui:codegen": "playwright codegen",
        "test:ui:report": "playwright show-report tests/ui-reports/html --port 9324 --host 0.0.0.0",
        "test:ui:install": "playwright install",
        "test:mutate": "bash bin/run-stryker.sh security",
        "test:mutate:all": "bash bin/run-stryker.sh all",
        "test:security": "bash ../security-checker.sh",
        "test:perf": "node scripts/perf/sizing-benchmark.js"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/runtime": "^7.29.2",
        "@playwright/test": "^1.58.2",
        "@stryker-mutator/core": "^9.6.1",
        "@stryker-mutator/jest-runner": "^9.6.1",
        "@testing-library/jest-dom": "^6.9.1",
        "axios": "^1.15.2",
        "babel-jest": "^30.2.0",
        "babel-plugin-transform-import-meta": "^2.3.3",
        "cross-env": "^10.1",
        "docdash": "^2.0.2",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "jsdoc": "^4.0.5",
        "jsdom": "^28.1.0",
        "lodash": "^4.18.1",
        "playwright-bdd": "^8.4.2",
        "vite": "^6.3.1"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "@hotwired/stimulus": "^3.2.2",
        "@hotwired/turbo": "^8.0.23",
        "@techstark/opencv-js": "^4.12.0-release.1",
        "bootstrap": "^5.3.8",
        "drawflow": "^0.0.60",
        "easymde": "^2.20.0",
        "face-api.js": "^0.22.2",
        "guifier": "^1.0.33",
        "pdfjs-dist": "^5.4.624",
        "picomatch": "^4.0.4",
        "popper.js": "^1.16.1",
        "qrcode": "^1.5.4",
        "smol-toml": "^1.6.1",
        "undici": "^7.24.6"
    },
    "browserslist": [
        "defaults"
    ],
    "overrides": {
        "fast-xml-parser": ">=5.3.4",
        "node-fetch": ">=2.6.7",
        "bn.js": "^5.2.3",
        "glob": "^13.0.6",
        "minimatch": "^10.2.2",
        "qs": "6.15.2",
        "rimraf": "^6.1.3",
        "webpack-dev-server": "^5.2.2"
    }
}
