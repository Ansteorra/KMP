{
  "plugins": ["plugins/markdown"],
  "source": {
    "include": [
      "assets/js",
      "plugins"
    ],
    "includePattern": "\\.(js|mjs)$",
    "excludePattern": "(^|\\/)(tests|node_modules|tmp|vendor|webroot|logs)"
  },
  "opts": {
    "encoding": "utf8",
    "destination": "../docs/api/js",
    "recurse": true,
    "readme": "../docs/10-javascript-development.md",
    "template": "./node_modules/docdash"
  },
  "docdash": {
    "search": true,
    "meta": {
      "title": "KMP JavaScript API",
      "description": "KMP JavaScript API reference for Stimulus controllers and plugin assets."
    },
    "menu": {
      "PHP API": {
        "href": "../php/index.html",
        "target": "_self"
      },
      "Docs Home": {
        "href": "../../index.html",
        "target": "_self"
      }
    }
  },
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "markdown": {
    "idInHeadings": true
  }
}
