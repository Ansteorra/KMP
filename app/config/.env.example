# Local Docker development defaults. Copy this file to app/config/.env and
# customize as needed for deployment environments.
export MYSQL_ROOT_PASSWORD='rootpassword'
export MYSQL_USERNAME='KMPSQLDEV'
export MYSQL_PASSWORD='P@ssw0rd'
export MYSQL_DB_NAME='KMP_DEV'

# Local Docker host port bindings. Defaults bind only to localhost so services
# are reachable from this machine without exposing them on the LAN.
export KMP_APP_BIND_ADDR='127.0.0.1'
export KMP_APP_PORT='8080'
export KMP_APP_URL='http://localhost:8080'
export KMP_DB_BIND_ADDR='127.0.0.1'
export KMP_DB_HOST_PORT='3306'
export KMP_MAILPIT_BIND_ADDR='127.0.0.1'
export KMP_MAILPIT_WEB_PORT='8025'
export KMP_MAILPIT_SMTP_PORT='1025'

# Optional space-separated local host aliases. Add matching entries to
# /etc/hosts, for example:
# 127.0.0.1 kmp.localhost admin.kmp.localhost
export KMP_HOST_ALIASES='kmp.localhost admin.kmp.localhost'

# Xdebug Configuration
export XDEBUG_MODE='debug,develop'
export XDEBUG_CLIENT_HOST='host.docker.internal'
export XDEBUG_CLIENT_PORT='9003'
export PHP_IDE_SERVER_NAME='KMP-Docker'

# Set to true to disable queue and scheduled cron jobs in local Docker.
export KMP_SKIP_CRON='false'

# Reset the Docker development database after a successful dev-up. The default
# uses --seed so local dev starts with the seeded test users and TestPassword.
export KMP_RESET_DB_ON_UP='true'
export KMP_RESET_DB_ON_UP_ARGS='--seed'

export EMAIL_DRIVER='smtp'
export EMAIL_FROM='noreply@localhost'
export EMAIL_SMTP_HOST='mailpit'
export EMAIL_SMTP_PORT='1025'
export EMAIL_SMTP_USERNAME=''
export EMAIL_SMTP_PASSWORD=''
export AZURE_COMMUNICATION_CONNECTION_STRING='endpoint=https://xxx.communication.azure.com/;accesskey=BASE64KEY'
export EMAIL_API_KEY='YOUR_SENDGRID_OR_RESEND_API_KEY'
export PATH_WKHTML='/usr/bin/wkhtmltopdf'
export AZURE_STORAGE_CONNECTION_STRING='SET THIS IF YOU ARE USING AZURE STORAGE'
export AWS_S3_BUCKET='SET THIS IF YOU ARE USING S3 STORAGE'
export AWS_DEFAULT_REGION='us-east-1'
export AWS_ACCESS_KEY_ID=''
export AWS_SECRET_ACCESS_KEY=''
export AWS_SESSION_TOKEN=''
export AWS_S3_PREFIX=''
export AWS_S3_ENDPOINT=''
export AWS_S3_USE_PATH_STYLE_ENDPOINT='false'
export PERF_REQUEST_LOG_ENABLED='false'
export PERF_SLOW_REQUEST_MS='750'
export PERF_LOG_ALL_REQUESTS='false'
export LOG_PERFORMANCE_URL=''
