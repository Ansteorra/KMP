# Local Docker development defaults. Copy this file to app/config/.env and
# customize as needed for deployment environments.
export POSTGRES_DB='KMP_DEV'
export POSTGRES_USER='KMPSQLDEV'
export POSTGRES_PASSWORD='kmpdevpass'
export DB_HOST='db'
export DB_PORT='5432'
export DB_USERNAME='KMPSQLDEV'
export DB_PASSWORD='kmpdevpass'
export DB_DATABASE='KMP_DEV'
export DATABASE_URL='postgres://KMPSQLDEV:kmpdevpass@db:5432/KMP_DEV'
export DATABASE_TEST_URL='postgres://KMPSQLDEV:kmpdevpass@db:5432/KMP_DEV_test'
export PLATFORM_DB_HOST='db'
export PLATFORM_DB_PORT='5432'
export PLATFORM_DB_USERNAME='KMPSQLDEV'
export PLATFORM_DB_PASSWORD='kmpdevpass'
export PLATFORM_DB_DATABASE='KMP_PLATFORM'
export PLATFORM_DB_TEST_DATABASE='KMP_PLATFORM_test'
export PLATFORM_DATABASE_URL='postgres://KMPSQLDEV:kmpdevpass@db:5432/KMP_PLATFORM'
export PLATFORM_DATABASE_TEST_URL='postgres://KMPSQLDEV:kmpdevpass@db:5432/KMP_PLATFORM_test'
export PLATFORM_HEALTH_RETRY_ATTEMPTS='0'
export PLATFORM_HEALTH_RETRY_DELAY_MS='0'
export KMP_TENANCY_ENABLED='true'
export KMP_REQUIRED_SCHEMA_VERSION=''
export KMP_PLATFORM_ADMIN_PORTAL_ENABLED='false'
export KMP_PLATFORM_DATA_CONSOLE_ENABLED='true'
export KMP_PLATFORM_ADMIN_HOSTS='platform.kmp.localhost'
export KMP_PLATFORM_ADMIN_ALLOWED_STATUSES='active'
export KMP_PLATFORM_ADMIN_DETAILED_LOGIN_ERRORS='true'
export KMP_AUTO_CREATE_DATABASES='true'
export KMP_ENV='local'
export KMP_SESSION_COOKIE_SECURE='false'
export KMP_DEV_TENANT_SLUG='kmp'
export KMP_DEV_TENANT_DISPLAY_NAME='KMP Development'
export KMP_DEV_TENANT_HOST='kmp.localhost'
# Database driver for CakePHP. Supported values: mysql, mariadb, postgres, pgsql.
# Local Docker development uses PostgreSQL 16.
export KMP_DB_DRIVER='postgres'

# Local Docker host port bindings. Defaults bind only to localhost so services
# are reachable from this machine without exposing them on the LAN.
export KMP_APP_BIND_ADDR='127.0.0.1'
export KMP_APP_PORT='8080'
export KMP_APP_URL='http://kmp.localhost:8080'
# Playwright UI tests (host): 127.0.0.1:8080 + Host kmp.localhost. In-container: http://127.0.0.1 + same Host.
export PLAYWRIGHT_BASE_URL='http://kmp.localhost:8080'
export PLAYWRIGHT_HOST_HEADER='kmp.localhost'
export PLAYWRIGHT_USE_DOCKER_PHP='1'
export KMP_DB_BIND_ADDR='127.0.0.1'
export KMP_DB_HOST_PORT='5432'
export KMP_PGADMIN_BIND_ADDR='127.0.0.1'
export KMP_PGADMIN_PORT='5050'
export KMP_PGADMIN_EMAIL='admin@kmpdev.org'
export KMP_PGADMIN_PASSWORD='kmpdevpass'
export KMP_MAILPIT_BIND_ADDR='127.0.0.1'
export KMP_MAILPIT_WEB_PORT='8025'
export KMP_MAILPIT_SMTP_PORT='1025'

# Optional space-separated local host aliases. Add matching entries to
# /etc/hosts, for example:
# 127.0.0.1 kmp.localhost kmp2.localhost platform.kmp.localhost
export KMP_HOST_ALIASES='kmp.localhost kmp2.localhost platform.kmp.localhost'

# Xdebug Configuration
export XDEBUG_MODE='debug,develop'
export XDEBUG_CLIENT_HOST='host.docker.internal'
export XDEBUG_CLIENT_PORT='9003'
export PHP_IDE_SERVER_NAME='KMP-Docker'

# The Docker app container disables cron; worker/scheduler services own local background processing.
export KMP_SKIP_CRON='true'
export KMP_SCHEDULER_POLL_INTERVAL='10'
export KMP_WORKFLOW_SCHEDULER_INTERVAL='60'
export KMP_ACTIVE_WINDOW_SYNC_INTERVAL='900'
export KMP_MEMBER_WARRANTABLE_SYNC_INTERVAL='86400'
export KMP_AGE_UP_MEMBERS_INTERVAL='86400'
export KMP_BACKUP_CHECK_INTERVAL='86400'

# Reset the Docker development database after a successful dev-up.
export KMP_RESET_DB_ON_UP='true'
export KMP_RESET_DB_ON_UP_ARGS='--seed'

export EMAIL_DRIVER='smtp'
export EMAIL_FROM='noreply@localhost'
export EMAIL_SMTP_HOST='mailpit'
export EMAIL_SMTP_PORT='1025'
export EMAIL_SMTP_USERNAME=''
export EMAIL_SMTP_PASSWORD=''
export AZURE_COMMUNICATION_CONNECTION_STRING='endpoint=https://xxx.communication.azure.com/;accesskey=BASE64KEY'
export EMAIL_API_KEY='YOUR_SENDGRID_OR_RESEND_API_KEY'
export PATH_WKHTML='/usr/bin/wkhtmltopdf'
export AZURE_STORAGE_AUTH_MODE='connectionString'
export AZURE_STORAGE_ACCOUNT_NAME=''
export AZURE_STORAGE_CONNECTION_STRING='SET THIS IF YOU ARE USING AZURE STORAGE'
export AZURE_STORAGE_CONTAINER_PREFIX='documents'
export AWS_S3_BUCKET='SET THIS IF YOU ARE USING S3 STORAGE'
export AWS_DEFAULT_REGION='us-east-1'
export AWS_ACCESS_KEY_ID=''
export AWS_SECRET_ACCESS_KEY=''
export AWS_SESSION_TOKEN=''
export AWS_S3_PREFIX=''
export AWS_S3_ENDPOINT=''
export AWS_S3_USE_PATH_STYLE_ENDPOINT='false'
export PERF_REQUEST_LOG_ENABLED='true'
export PERF_SLOW_REQUEST_MS='750'
export PERF_LOG_ALL_REQUESTS='true'
export PERF_DB_QUERY_LOG_ENABLED='true'
export PERF_KINGDOM_TAG='jh_local_dev_workflow'
export LOG_QUERIES_URL=''
export LOG_PERFORMANCE_URL=''
export APPINSIGHTS_CONNECTION_STRING=''
export APPINSIGHTS_LOG_ENABLED='true'
export APPINSIGHTS_CLOUD_ROLE='kmp'
export APPINSIGHTS_CLOUD_ROLE_INSTANCE=''
export APPINSIGHTS_LOG_TIMEOUT='2.0'
export APPINSIGHTS_LOG_BATCH_SIZE='25'
export APPINSIGHTS_QUERY_LOG_ENABLED='true'
export APPINSIGHTS_QUERY_SAMPLE_RATE='10.0'
export APPINSIGHTS_ERROR_LOG_ENABLED='true'
export LOG_QUERIES_FILE_SIZE='10MB'
export LOG_QUERIES_FILE_ROTATE='5'
export LOG_PERFORMANCE_FILE_SIZE='10MB'
export LOG_PERFORMANCE_FILE_ROTATE='5'

# Platform audit WORM mirror. Disabled by default so production cannot
# accidentally write audit mirrors to ephemeral local disk. For local testing,
# set sink=file and keep the path under app/tmp. Production Azure deployments
# should use an immutable Blob container with time-based retention/legal hold and
# wire the approved sink before enabling fail-closed behavior.
export PLATFORM_AUDIT_WORM_SINK='disabled'
export PLATFORM_AUDIT_WORM_FILE_PATH='/var/www/html/tmp/platform_audit_worm.jsonl'
export PLATFORM_AUDIT_WORM_FAIL_CLOSED='false'
export PLATFORM_AUDIT_WORM_AZURE_ACCOUNT=''
export PLATFORM_AUDIT_WORM_AZURE_CONTAINER=''
export PLATFORM_AUDIT_WORM_AZURE_PREFIX='platform-audit/'
export PLATFORM_AUDIT_WORM_AZURE_IMMUTABILITY_POLICY='time-based-retention-or-legal-hold'
