{
    "nodes": {
        "trigger": {
            "type": "trigger",
            "label": "Bestowal Update Requested",
            "config": {
                "event": "Awards.BestowalUpdateRequested",
                "entityIdField": "bestowalId"
            },
            "position": {
                "x": 50,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "update-bestowal"
                }
            ]
        },
        "update-bestowal": {
            "type": "action",
            "label": "Update Bestowal",
            "config": {
                "action": "Awards.UpdateBestowal",
                "params": {
                    "bestowalId": "$.trigger.bestowalId",
                    "data": "$.trigger.data",
                    "actorId": "$.trigger.actorId"
                }
            },
            "position": {
                "x": 350,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "update-succeeded"
                }
            ]
        },
        "update-succeeded": {
            "type": "condition",
            "label": "Update Succeeded?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.nodes.update-bestowal.result.success",
                "value": true
            },
            "position": {
                "x": 650,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "end-success",
                    "label": "Updated"
                },
                {
                    "port": "false",
                    "target": "end-failed",
                    "label": "Failed"
                }
            ]
        },
        "end-success": {
            "type": "end",
            "label": "Update Complete",
            "config": {
                "result": "$.nodes.update-bestowal.result"
            },
            "position": {
                "x": 950,
                "y": 225
            },
            "outputs": []
        },
        "end-failed": {
            "type": "end",
            "label": "Update Failed",
            "config": {
                "result": "$.nodes.update-bestowal.result"
            },
            "position": {
                "x": 950,
                "y": 375
            },
            "outputs": []
        }
    },
    "startNode": "trigger"
}
