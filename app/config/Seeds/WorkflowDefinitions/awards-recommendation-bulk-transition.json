{
    "nodes": {
        "trigger": {
            "type": "trigger",
            "label": "Bulk Recommendation Transition Requested",
            "config": {
                "event": "Awards.RecommendationBulkTransitionRequested"
            },
            "position": {
                "x": 50,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "bulk-transition"
                }
            ]
        },
        "bulk-transition": {
            "type": "action",
            "label": "Bulk Transition Recommendations",
            "config": {
                "action": "Awards.BulkTransitionState",
                "params": {
                    "recommendationIds": "$.trigger.recommendationIds",
                    "targetState": "$.trigger.targetState",
                    "data": "$.trigger.data",
                    "actorId": "$.trigger.actorId"
                }
            },
            "position": {
                "x": 350,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "bulk-succeeded"
                }
            ]
        },
        "bulk-succeeded": {
            "type": "condition",
            "label": "Bulk Transition Succeeded?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.nodes.bulk-transition.result.success",
                "value": true
            },
            "position": {
                "x": 650,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "need-to-schedule-check",
                    "label": "Transitioned"
                },
                {
                    "port": "false",
                    "target": "end-failed",
                    "label": "Failed"
                }
            ]
        },
        "need-to-schedule-check": {
            "type": "condition",
            "label": "Target State Need to Schedule?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.nodes.bulk-transition.result.data.targetState",
                "value": "Need to Schedule"
            },
            "position": {
                "x": 800,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "create-bestowals",
                    "label": "Need to Schedule"
                },
                {
                    "port": "false",
                    "target": "end-success",
                    "label": "Other State"
                }
            ]
        },
        "create-bestowals": {
            "type": "action",
            "label": "Create Bestowals For Recommendations",
            "config": {
                "action": "Awards.CreateBestowalsForRecommendations",
                "params": {
                    "recommendationIds": "$.trigger.recommendationIds",
                    "actorId": "$.trigger.actorId"
                }
            },
            "position": {
                "x": 1050,
                "y": 175
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "end-success"
                }
            ]
        },
        "end-success": {
            "type": "end",
            "label": "Bulk Transition Complete",
            "config": {
                "result": "$.nodes.bulk-transition.result"
            },
            "position": {
                "x": 1300,
                "y": 225
            },
            "outputs": []
        },
        "end-failed": {
            "type": "end",
            "label": "Bulk Transition Failed",
            "config": {
                "result": "$.nodes.bulk-transition.result"
            },
            "position": {
                "x": 950,
                "y": 375
            },
            "outputs": []
        }
    },
    "startNode": "trigger"
}
