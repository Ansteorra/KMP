{
    "nodes": {
        "trigger": {
            "type": "trigger",
            "label": "Recommendation State Changed",
            "config": {
                "event": "Awards.RecommendationStateChanged",
                "entityIdField": "recommendationId"
            },
            "position": {
                "x": 50,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "is-handoff-state"
                }
            ]
        },
        "is-handoff-state": {
            "type": "condition",
            "label": "Need to Schedule?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.trigger.newState",
                "value": "Need to Schedule"
            },
            "position": {
                "x": 350,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "end-noop",
                    "label": "Legacy handoff disabled"
                },
                {
                    "port": "false",
                    "target": "end-noop",
                    "label": "No bestowal"
                }
            ]
        },
        "end-noop": {
            "type": "end",
            "label": "State Change Complete",
            "config": {
                "result": {
                    "success": true,
                    "skipped": true,
                    "reason": "Recommendation state changes no longer create bestowals."
                }
            },
            "position": {
                "x": 650,
                "y": 425
            },
            "outputs": []
        }
    },
    "startNode": "trigger"
}
