{
    "nodes": {
        "trigger": {
            "type": "trigger",
            "label": "Recommendation State Changed",
            "config": {
                "event": "Awards.RecommendationStateChanged",
                "entityIdField": "recommendationId"
            },
            "position": {
                "x": 50,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "is-handoff-state"
                }
            ]
        },
        "is-handoff-state": {
            "type": "condition",
            "label": "Need to Schedule?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.trigger.newState",
                "value": "Need to Schedule"
            },
            "position": {
                "x": 350,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "create-bestowal",
                    "label": "Create bestowal"
                },
                {
                    "port": "false",
                    "target": "end-noop",
                    "label": "No bestowal"
                }
            ]
        },
        "create-bestowal": {
            "type": "action",
            "label": "Create Bestowal",
            "config": {
                "action": "Awards.CreateBestowal",
                "params": {
                    "recommendationId": "$.trigger.recommendationId",
                    "actorId": "$.trigger.actorId"
                }
            },
            "position": {
                "x": 650,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "create-succeeded"
                }
            ]
        },
        "create-succeeded": {
            "type": "condition",
            "label": "Bestowal Created?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.nodes.create-bestowal.result.success",
                "value": true
            },
            "position": {
                "x": 950,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "end-success",
                    "label": "Created"
                },
                {
                    "port": "false",
                    "target": "end-failed",
                    "label": "Failed"
                }
            ]
        },
        "end-success": {
            "type": "end",
            "label": "State Change Complete",
            "config": {
                "result": "$.nodes.create-bestowal.result"
            },
            "position": {
                "x": 1250,
                "y": 225
            },
            "outputs": []
        },
        "end-noop": {
            "type": "end",
            "label": "State Change Complete",
            "config": {
                "result": {
                    "success": true,
                    "skipped": true,
                    "reason": "No handoff bestowal required."
                }
            },
            "position": {
                "x": 650,
                "y": 425
            },
            "outputs": []
        },
        "end-failed": {
            "type": "end",
            "label": "Bestowal Creation Failed",
            "config": {
                "result": "$.nodes.create-bestowal.result"
            },
            "position": {
                "x": 1250,
                "y": 375
            },
            "outputs": []
        }
    },
    "startNode": "trigger"
}
