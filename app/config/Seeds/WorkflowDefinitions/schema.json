{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://kmp.local/schemas/workflow-definition.schema.json",
    "title": "KMP Workflow Definition",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "$schema",
        "schemaVersion",
        "nodes"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "schemaVersion": {
            "type": "string",
            "const": "1.0"
        },
        "startNode": {
            "type": "string",
            "minLength": 1
        },
        "nodes": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
                "$ref": "#/$defs/node"
            }
        }
    },
    "$defs": {
        "node": {
            "type": "object",
            "additionalProperties": true,
            "required": [
                "type",
                "config",
                "outputs"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "trigger",
                        "action",
                        "condition",
                        "approval",
                        "fork",
                        "join",
                        "loop",
                        "forEach",
                        "delay",
                        "subworkflow",
                        "humanTask",
                        "stateMachine",
                        "end"
                    ]
                },
                "label": {
                    "type": "string"
                },
                "config": {
                    "type": "object"
                },
                "position": {
                    "type": "object",
                    "properties": {
                        "x": {
                            "type": "number"
                        },
                        "y": {
                            "type": "number"
                        }
                    }
                },
                "outputs": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/output"
                    }
                }
            }
        },
        "output": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "port": {
                    "type": "string"
                },
                "target": {
                    "type": "string",
                    "minLength": 1
                },
                "label": {
                    "type": "string"
                }
            }
        }
    }
}
