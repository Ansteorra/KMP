# KMP Docker Development Environment Variables
# Copy this to .env in the project root and customize as needed
#
# Usage: cp docker/.env.example .env

# Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DB_NAME=KMP_DEV
MYSQL_USERNAME=KMPSQLDEV
MYSQL_PASSWORD=P@ssw0rd

# Email Configuration (Mailpit handles this, but app needs these)
# EMAIL_DRIVER: smtp (default), azure, sendgrid, resend
EMAIL_DRIVER=smtp
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=

# Azure Communication Services (when EMAIL_DRIVER=azure)
# AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://xxx.communication.azure.com/;accesskey=BASE64KEY

# SendGrid / Resend (when EMAIL_DRIVER=sendgrid or resend)
# EMAIL_API_KEY=

# Optional: Azure Storage (for file uploads)
# AZURE_STORAGE_CONNECTION_STRING=your-connection-string
